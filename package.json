{
  "name": "express-boilerplate",
  "version": "1.0.0",
  "description": "Generate template and config so it will auto provisioning in Harvester.",
  "keywords": [
    "docker",
    "nodejs",
    "expressjs",
    "backend"
  ],
  "bin": "index.js",
  "pkg": {
    "assets": [
      "src/templates/**/*",
      "node_modules/swagger-ui-dist/**/*",
      "uploads/**/*",
      "swagger.json",
      "docs"
    ],
    "scripts": [
      "src/**/*.js"
    ],
    "targets": [
      "node24-linux-x64",
      "node24-win-x64"
    ],
    "outputPath": "dist"
  },
  "license": "MIT",
  "author": "zed378",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js --forceExit",
    "test:unit": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js --forceExit",
    "test:e2e": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js --config jest.e2e.config.js --forceExit --runInBand",
    "test:watch": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js --coverage",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build": "bun build index.js --compile --loader:.html=text --target bun-linux-x64 --outfile dist/boilerplate",
    "swagger:generate": "node src/utils/generateSwagger.util.js",
    "migrate": "node src/scripts/migrate.js up",
    "migrate:undo": "node src/scripts/migrate.js down",
    "migrate:status": "node src/scripts/migrate.js pending",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "prettier": "prettier --check \"src/**/*.js\"",
    "prettier:fix": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "aedes": "^1.1.1",
    "aedes-server-factory": "^0.2.1",
    "amqplib": "^2.0.1",
    "archiver": "^8.0.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cls-hooked": "^4.2.2",
    "compression": "^1.8.1",
    "connect-timeout": "^1.9.1",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "fs-extra": "^11.3.5",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.11.1",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "jwk-to-pem": "^2.0.7",
    "markdown-it": "^14.2.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.2",
    "morgan": "^1.11.0",
    "mqtt": "^5.15.2",
    "multer": "^2.2.0",
    "mustache": "^4.2.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "otplib": "^13.4.1",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^25.2.0",
    "qrcode": "^1.5.4",
    "randomstring": "^1.3.1",
    "rotating-file-stream": "^3.2.9",
    "sanitize-html": "^2.17.6",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "stripe": "^22.3.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^6.0.2",
    "umzug": "^3.8.3",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "markdown-pdf": "^11.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4"
  }
}